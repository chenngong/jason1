{
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://mysavegoal.com/$1",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "www.mysavegoal.com"
        }
      ]
    },
    {
      "source": "/(.*)",
      "destination": "https://mysavegoal.com/$1",
      "permanent": true,
      "has": [
        {
          "type": "protocol",
          "value": "http"
        }
      ]
    }
  ]
}
